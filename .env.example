# Database driver: "memory" (default, ephemeral) or "supabase" (persistent)
DB_DRIVER=memory

# Supabase Postgres (required when DB_DRIVER=supabase)
# Get from supabase.com → Project → Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URL on port 6543 for Vercel/serverless,
# or the "Session" pooler URL on port 5432 for long-running processes.
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase JS client (optional — not required by the Postgres adapter, kept for future Storage/Realtime)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE=eyJhbGciOi...

# Session cookie secret (rotate per environment)
SESSION_SECRET=change-me-to-a-32-char-random-string
